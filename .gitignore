backend/node_modules/.prisma/

# -------------------------------------------------------
# IDEs y editores
# -------------------------------------------------------
.vscode/settings.json
.idea/
*.swp
*.swo

# -------------------------------------------------------
# Sistema operativo
# -------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# -------------------------------------------------------
