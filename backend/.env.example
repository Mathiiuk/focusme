# FocusFlow AI — Variables de entorno del backend
# NUNCA comitear el archivo .env real — este es solo el template

# -------------------------------------------------------
# Base de datos PostgreSQL
# En desarrollo: instancia local o Render
# En producción: Render PostgreSQL (copiar la connection string del dashboard)
# -------------------------------------------------------
DATABASE_URL="postgresql://usuario:contraseña@localhost:5432/focusflow_dev"

# -------------------------------------------------------
# JWT — Usar un string aleatorio de mínimo 64 caracteres
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# -------------------------------------------------------
JWT_SECRET="tu_jwt_secret_de_64_caracteres_minimo_aqui"

# -------------------------------------------------------
# OpenAI API
# Obtener en: https://platform.openai.com/api-keys
# Si está vacío, el motor usa respuestas mock automáticamente
# -------------------------------------------------------
OPENAI_API_KEY="sk-..."

# -------------------------------------------------------
# URL del frontend (necesaria para CORS)
# En desarrollo: http://localhost:5173
# En producción: https://tu-app.vercel.app
# -------------------------------------------------------
CLIENT_URL="http://localhost:5173"

# -------------------------------------------------------
# Entorno de Node
# Valores válidos: development | production
# -------------------------------------------------------
NODE_ENV="development"

# -------------------------------------------------------
# Puerto del servidor (Render lo configura automáticamente)
# -------------------------------------------------------
PORT=3001
